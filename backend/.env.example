# =============================================================================
# MacroFactor Trader — 生产环境配置示例
# =============================================================================
# 复制此文件为 .env 并填入实际值：
#   cp backend/.env.example backend/.env
# =============================================================================

# 环境: development | staging | production
ENV=production

# 管理端点 API Key（生产环境必须设置强密码）
ADMIN_API_KEY=change-me-to-a-strong-random-key

# CORS 白名单（同域部署时可以是同一域名）
CORS_ORIGINS=https://ajan03.xyz

# 数据库
# SQLite（简单零配置，适合中小规模）
DATABASE_URL=sqlite+aiosqlite:///var/www/ajan03.xyz/backend/macrofactor.db
# PostgreSQL（生产级，需要提前创建数据库）
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/macrofactor

# 缓存: memory | redis
CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
